# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hrms

# Sync Agent API Key (Generate a secure random string)
SYNC_AGENT_API_KEY=your_secure_random_api_key_here_change_this_in_production

# Realtime Software Bearer Token
REALTIME_BEARER_TOKEN=abc123xyz

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Socket.IO Configuration
SOCKET_PORT=5001

# JWT Secret (if using JWT authentication)
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
