import { Request, Response, NextFunction } from 'express';
import { Employee } from '../models/employee.model';
import { Reimbursement } from '../models/reimbursement.model';
import { Attendance } from '../models/attendance.model';
import { AppError } from '../middleware/error.middleware';

export class AccountsController {
  getDashboard = async (_req: Request, res: Response: Promise<Response | void> => {
    try {
      const totalEmployees = await Employee.countDocuments({ status: 'Active' });
      const totalReimbursements = await Reimbursement.countDocuments({ status: 'Pending' });
      const totalPayrollProcessed = await Reimbursement.countDocuments({ status: 'Paid' });
      
      const currentMonth = new Date().getMonth();
      const currentYear = new Date().getFullYear();
      const startDate = new Date(currentYear, currentMonth, 1);
      const endDate = new Date(currentYear, currentMonth + 1, 0, 23, 59, 59);

      const monthlyPayrollAmount = await Reimbursement.aggregate([
        {
          $match: {
            status: 'Paid',
            paidDate: { $gte: startDate, $lte: endDate }
          }
        },
        {
          $group: {
            _id: null,
            total: { $sum: '$amountClaimed' }
          }
        }
      ]);

      const monthlyAttendance = await Attendance.aggregate([
        {
          $match: {
            date: { $gte: startDate, $lte: endDate }
          }
        },
        {
          $group: {
            _id: null,
            totalPresent: { $sum: { $cond: [{ $eq: ['$status', 'Present'] }, 1, 0] } },
            totalAbsent: { $sum: { $cond: [{ $eq: ['$status', 'Absent'] }, 1, 0] } },
            totalLeave: { $sum: { $cond: [{ $eq: ['$status', 'Leave'] }, 1, 0] } }
          }
        }
      ]);

      return res.status(200).json({
        success: true,
        data: {
          totalEmployees,
          totalReimbursements,
          totalPayrollProcessed,
          monthlyPayrollAmount: monthlyPayrollAmount[0]?.total || 0,
          attendance: monthlyAttendance[0] || { totalPresent: 0, totalAbsent: 0, totalLeave: 0 }
        },
        message: 'Dashboard data retrieved successfully'
      });
    } catch (error) {
    return;
    return;
      return;
    return;
    }
  };

  getReports = async (_req: Request, res: Response: Promise<Response | void> => {
    try {
      const { reportType, startDate, endDate, departmentId } = req.query;
      
      let data: any = {};

      if (reportType === 'payroll') {
        const matchStage: any = {};
        if (startDate && endDate) {
          matchStage.paidDate = { $gte: new Date(startDate as string), $lte: new Date(endDate as string) };
        }

        const pipeline: any[] = [
          { $match: matchStage },
          {
            $lookup: {
              from: 'employees',
              localField: 'employeeId',
              foreignField: '_id',
              as: 'employee'
            }
          },
          { $unwind: { path: '$employee', preserveNullAndEmptyArrays: true } }
        ];

        if (departmentId) {
          const employeeIds = await Employee.find({ departmentId: departmentId as string }).distinct('_id');
          pipeline.push({ $match: { employeeId: { $in: employeeIds } } });
        }

        data.payroll = await Reimbursement.aggregate(pipeline);
      } else if (reportType === 'reimbursement') {
        const matchStage: any = {};
        if (startDate && endDate) {
          matchStage.submittedOn = { $gte: new Date(startDate as string), $lte: new Date(endDate as string) };
        }

        let query = Reimbursement.find(matchStage).populate('employeeId');
        
        if (departmentId && typeof departmentId === 'string') {
          const employeeIds = await Employee.find({ departmentId }).distinct('_id');
          query = query.where('employeeId').in(employeeIds);
        }

        data.reimbursements = await query.sort({ submittedOn: -1 });
      } else if (reportType === 'attendance') {
        const matchStage: any = {};
        if (startDate && endDate) {
          matchStage.date = { $gte: new Date(startDate as string), $lte: new Date(endDate as string) };
        }

        const pipeline: any[] = [
          { $match: matchStage },
          {
            $lookup: {
              from: 'employees',
              localField: 'employeeId',
              foreignField: '_id',
              as: 'employee'
            }
          },
          { $unwind: { path: '$employee', preserveNullAndEmptyArrays: true } },
          {
            $lookup: {
              from: 'departments',
              localField: 'employee.departmentId',
              foreignField: '_id',
              as: 'department'
            }
          },
          { $unwind: { path: '$department', preserveNullAndEmptyArrays: true } }
        ];

        if (departmentId && typeof departmentId === 'string') {
          const employeeIds = await Employee.find({ departmentId: departmentId as any }).distinct('_id');
          pipeline.push({ $match: { employeeId: { $in: employeeIds } } });
        }

        data.attendance = await Attendance.aggregate(pipeline);
      } else {
        throw new AppError('Invalid report type. Valid types: payroll, reimbursement, attendance', 400, 'INVALID_REPORT_TYPE');
      }

      return res.status(200).json({
        success: true,
        data,
        message: 'Report retrieved successfully'
      });
    } catch (error) {
      next(error);
    }
  };
}
