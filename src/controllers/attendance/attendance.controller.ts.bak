import { Request, Response, NextFunction } from 'express';
import { Attendance } from '../../models/attendance.model';
import { Employee } from '../../models/employee.model';
import { AppError } from '../../middleware/error.middleware';


export class AttendanceController {
  getAllAttendance = async (req: Request, res: Response, next: NextFunction): Promise<Response | void> => {
    try {
      const { employeeId, date, status, departmentId, page = 1, pageSize = 10 } = req.query;
      
      const filter: any = {};
      if (employeeId) filter.employeeId = employeeId;
      if (date && typeof date === 'string') filter.date = new Date(date);
      if (status) filter.status = status;

      let query = Attendance.find(filter);
      
      if (departmentId && typeof departmentId === 'string') {
        const employeeIds = await Employee.find({ departmentId }).distinct('_id');
        query = query.where('employeeId').in(employeeIds);
      }

      const skip = (Number(page) - 1) * Number(pageSize);
      const [items, total] = await Promise.all([
        query.populate('employeeId').sort({ date: -1 }).skip(skip).limit(Number(pageSize)),
        Attendance.countDocuments(filter)
      ]);

      return res.status(200).json({
        success: true,
        data: {
          items,
          pagination: {
            page: Number(page),
            pageSize: Number(pageSize),
            total,
            totalPages: Math.ceil(total / Number(pageSize)),
          },
        },
        message: 'Attendance records retrieved successfully',
      });
    } catch (error) {
      next(error);
    }
  };

