  getAttendanceSummary = async (req: Request, res: Response: Promise<Response | void> => {
    try {
      const { startDate, endDate, departmentId } = req.query;

      const matchStage: any = {};
      if (startDate && typeof startDate === 'string') {
        matchStage.date = { ...matchStage.date, $gte: new Date(startDate) };
      }
      ax(eo)
      const pipeline: any[] = [
        { $match: matchStage },
      ];
e, next: NxtFunction)
      if (departmentId && typeof departmentId === 'string') {
        const employeeIds = await Employee.find({ departmentId }).distinct('_id');
        pipeline.push({ $match: { employeeId: { $in: employeeIds.map(id => id.toString()) } } });
      }

      pipeline.push({
        $group: {
          _id: null,
          total: { $sum: 1 },
          present: { $sum: { $cond: [{ $eq: ['$status', 'Present'] }, 1, 0] } },
          absent: { $sum: { $cond: [{ $eq: ['$status', 'Absent'] }, 1, 0] } },
          late: { $sum: { $cond: [{ $eq: ['$status', 'Late'] }, 1, 0] } },
          early_out: { $sum: { $cond: [{ $eq: ['$status', 'Early Out'] }, 1, 0] } },
          on_field: { $sum: { $cond: [{ $eq: ['$status', 'On Field'] }, 1, 0] } },
          on_leave: { $sum: { $cond: [{ $eq: ['$status', 'Leave'] }, 1, 0] } },
          avgHours: { $avg: '$totalHours' },
          totalOvertime: { $sum: '$overtimeHours' },
        }
      });

      const result = await Attendance.aggregate(pipeline);

      return res.status(200).json({
        success: true,
        data: result[0] || { total: 0, present: 0, absent: 0, late: 0, early_out: 0, on_field: 0, on_leave: 0, avgHours: 0, totalOvertime: 0 },
        message: 'Attendance summary retrieved successfully',
      });
    } catch (error) {
    return;
    return;
      return;
    return;
    }
  };

  private calculateTotalHours(punchIn: string, punchOut: string): number {
    const [inHours, inMinutes] = punchIn.split(':').map(Number);
    const [outHours, outMinutes] = punchOut.split(':').map(Number);

    const inTotalMinutes = inHours * 60 + inMinutes;
    const outTotalMinutes = outHours * 60 + outMinutes;

    const diffMinutes = outTotalMinutes - inTotalMinutes;
    return Math.round((diffMinutes / 60) * 100) / 100;
  }
