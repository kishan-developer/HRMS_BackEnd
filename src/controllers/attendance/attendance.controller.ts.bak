        throw new AppError('Attendance record not found', 404, 'ATTENDANCE_NOT_FOUND');
      }

      return res.status(200).json({
        success: true,
        data: attendance,
        message: 'Attendance record retrieved successfully',
      });
    } catch (error) {
    return;
